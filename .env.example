# NOPE Environment Configuration
# Copy this file to .env and fill in your values

# Environment
NODE_ENV=development
PYTHON_ENV=development

# API Keys (Required for enrichment)
GITHUB_TOKEN=your_github_token_here
SHODAN_API_KEY=your_shodan_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
DEPS_DEV_API_KEY=optional_deps_dev_key

# Database
DATABASE_URL=sqlite:///data/nope.db
REDIS_URL=redis://localhost:6379/0

# Caching
CACHE_TTL_HOURS=24
CVE_CACHE_DAYS=10
KEV_CACHE_HOURS=4

# EPSS Configuration
EPSS_THRESHOLD=0.10  # 88th percentile (default)
EPSS_MIN_PERCENTILE=0.88
DAILY_CVE_TARGET=5
DAILY_CVE_MAX=8

# ML Model Configuration
MODEL_VERSION=2.0
MODEL_PATH=data/models/
ENABLE_NEURAL_TRAINING=true
PREDICTION_CONFIDENCE_MIN=0.5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RATE_LIMIT=100

# Frontend Configuration
SITE_URL=https://williamzujkowski.github.io/NOPE
SITE_TITLE=NOPE - Network Operational Patch Evaluator
ENABLE_WEBSOCKET=true
WEBSOCKET_URL=wss://api.nope.security/live

# Monitoring
PROMETHEUS_GATEWAY=http://localhost:9091
ENABLE_METRICS=true
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true

# Security
JWT_SECRET=generate_a_strong_secret_key_here
ALLOWED_ORIGINS=http://localhost:8080,https://williamzujkowski.github.io

# GitHub Actions
GITHUB_REPOSITORY=williamzujkowski/NOPE
GITHUB_PAGES_BRANCH=gh-pages

# Feature Flags
ENABLE_EARLY_WARNING=true
ENABLE_CORRELATION_ENGINE=true
ENABLE_SUPPLY_CHAIN_ANALYSIS=true
ENABLE_EXPLOIT_TRACKING=true

# Emergency Response
EMERGENCY_MODE=false
FORCE_REBUILD=false
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE