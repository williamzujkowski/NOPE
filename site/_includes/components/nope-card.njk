<!-- Enhanced NOPE Card Component with Risk Visualization and Alpine.js Reactivity -->
<div class="nope-card bg-white dark:bg-gray-800 rounded-lg border-2 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer"
     :class="getThreatLevelColor(prediction.threat_level)"
     @click="showPredictionDetails(prediction)">
    
    <!-- Card Header with NOPE Score and Status -->
    <div class="p-6">
        <div class="flex justify-between items-start mb-4">
            <div class="flex items-center space-x-4">
                <!-- Threat Icon -->
                <div class="text-4xl" x-text="getPredictionIcon(prediction)"></div>
                <div>
                    <!-- CVE ID as clickable link -->
                    <h3 class="text-xl font-bold">
                        <a :href="`/cves/${prediction.cve_id}.html`" 
                           class="hover:underline transition-colors"
                           @click.stop
                           x-text="prediction.cve_id"></a>
                    </h3>
                    <div class="flex gap-2 mt-2">
                        <!-- Threat Level Badge -->
                        <span class="text-xs px-3 py-1 rounded-full font-semibold uppercase tracking-wide"
                              :class="getThreatLevelColor(prediction.threat_level)"
                              x-text="prediction.threat_level"></span>
                        
                        <!-- Confidence Badge -->
                        <span class="text-xs px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-700"
                              :class="getConfidenceColor(prediction.confidence)">
                            <span x-text="`${((prediction.confidence || 0) * 100).toFixed(0)}%`"></span> confidence
                        </span>
                        
                        <!-- Exploitation Status -->
                        <span x-show="prediction.will_be_exploited"
                              class="text-xs px-3 py-1 rounded-full bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                            🎯 Will be exploited
                        </span>
                    </div>
                </div>
            </div>
            
            <!-- NOPE Risk Score Display -->
            <div class="text-right">
                <div class="relative">
                    <!-- Circular progress indicator -->
                    <div class="w-20 h-20 relative">
                        <svg class="w-20 h-20 transform -rotate-90" viewBox="0 0 36 36">
                            <!-- Background circle -->
                            <path d="m18,2.0845 a 15.9155,15.9155 0 0,1 0,31.831 a 15.9155,15.9155 0 0,1 0,-31.831"
                                  fill="none" stroke="currentColor" stroke-width="2" 
                                  class="text-gray-200 dark:text-gray-700" stroke-dasharray="100, 100"></path>
                            <!-- Progress circle -->
                            <path d="m18,2.0845 a 15.9155,15.9155 0 0,1 0,31.831 a 15.9155,15.9155 0 0,1 0,-31.831"
                                  fill="none" stroke="currentColor" stroke-width="3" 
                                  :class="prediction.risk_score >= 70 ? 'text-red-500' : prediction.risk_score >= 50 ? 'text-yellow-500' : 'text-green-500'"
                                  :stroke-dasharray="`${prediction.risk_score || 0}, 100`"></path>
                        </svg>
                        <!-- Score text in center -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="text-center">
                                <div class="text-2xl font-bold" x-text="prediction.risk_score || 0"></div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">NOPE</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Prediction Summary -->
        <div class="mb-6 p-4 rounded-lg bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 border border-blue-100 dark:border-blue-800">
            <div class="flex items-center gap-2 mb-3">
                <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                </svg>
                <span class="font-semibold text-blue-900 dark:text-blue-100">AI Prediction Summary</span>
            </div>
            
            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="font-medium text-gray-700 dark:text-gray-300">Exploitation Likelihood:</span>
                    <span class="font-semibold" 
                          :class="prediction.will_be_exploited ? 'text-red-600 dark:text-red-400' : 'text-yellow-600 dark:text-yellow-400'"
                          x-text="prediction.will_be_exploited ? 'High' : 'Moderate'"></span>
                </div>
                <div x-show="prediction.time_to_exploitation" class="flex justify-between">
                    <span class="font-medium text-gray-700 dark:text-gray-300">Time to Exploitation:</span>
                    <span class="font-bold text-red-600 dark:text-red-400"
                          x-text="formatTimeToExploitation(prediction.time_to_exploitation)"></span>
                </div>
                <div class="flex justify-between">
                    <span class="font-medium text-gray-700 dark:text-gray-300">Recommended Action:</span>
                    <span class="font-semibold text-blue-600 dark:text-blue-400 italic text-right max-w-xs"
                          x-text="prediction.recommendation || 'Monitor closely'"></span>
                </div>
            </div>
        </div>
        
        <!-- Key Risk Factors -->
        <div class="mb-6" x-show="prediction.key_risk_factors && prediction.key_risk_factors.length > 0">
            <h4 class="font-semibold mb-3 flex items-center gap-2 text-gray-900 dark:text-gray-100">
                <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
                Key Risk Factors
            </h4>
            <div class="space-y-2">
                <template x-for="(factor, index) in (prediction.key_risk_factors || []).slice(0, 3)" :key="index">
                    <div class="flex items-start gap-3 p-3 rounded-md bg-orange-50 dark:bg-orange-900/20 border border-orange-100 dark:border-orange-800">
                        <span class="text-orange-500 mt-0.5 text-lg">⚡</span>
                        <div class="flex-1">
                            <div class="font-medium text-orange-900 dark:text-orange-100" 
                                 x-text="factor.factor"></div>
                            <div class="text-sm text-orange-700 dark:text-orange-300 mt-1" 
                                 x-text="factor.description"></div>
                            <div class="text-xs text-orange-600 dark:text-orange-400 mt-1">
                                Impact: <span class="font-medium capitalize" x-text="factor.severity || 'medium'"></span>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>
        
        <!-- CVE Details Section -->
        <div class="mb-6 p-4 rounded-lg bg-gray-50 dark:bg-gray-700/50">
            <h4 class="font-semibold mb-2 text-gray-900 dark:text-gray-100">Vulnerability Details</h4>
            <p class="text-sm text-gray-700 dark:text-gray-300 line-clamp-3 mb-3" 
               x-text="prediction.description || 'No description available'"></p>
            
            <!-- Technical Details Grid -->
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <div class="font-medium text-gray-600 dark:text-gray-400 mb-1">CVSS Score</div>
                    <div class="font-semibold" x-text="prediction.cvss_score || 'N/A'"></div>
                </div>
                <div>
                    <div class="font-medium text-gray-600 dark:text-gray-400 mb-1">EPSS Score</div>
                    <div class="font-semibold" x-text="`${((prediction.epss_score || 0) * 100).toFixed(1)}%`"></div>
                </div>
                <div>
                    <div class="font-medium text-gray-600 dark:text-gray-400 mb-1">Published</div>
                    <div class="font-semibold" x-text="formatDate(prediction.date_published)"></div>
                </div>
                <div>
                    <div class="font-medium text-gray-600 dark:text-gray-400 mb-1">Vendor</div>
                    <div class="font-semibold" x-text="prediction.vendor || 'Unknown'"></div>
                </div>
            </div>
        </div>
        
        <!-- Model Contributions (Expandable) -->
        <details class="mb-6">
            <summary class="cursor-pointer font-semibold text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                AI Model Contributions
            </summary>
            <div class="mt-3 space-y-2">
                <template x-for="[model, contribution] in Object.entries(prediction.model_contributions || {})" 
                          :key="model">
                    <div class="flex items-center justify-between p-2 rounded bg-gray-100 dark:bg-gray-600">
                        <span class="text-xs font-medium" 
                              x-text="model.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())"></span>
                        <div class="flex items-center space-x-2">
                            <div class="w-16 bg-gray-200 dark:bg-gray-500 rounded-full h-2">
                                <div class="bg-blue-600 h-2 rounded-full transition-all duration-500" 
                                     :style="`width: ${(contribution * 100)}%`"></div>
                            </div>
                            <span class="text-xs font-bold w-10 text-right" 
                                  x-text="`${(contribution * 100).toFixed(1)}%`"></span>
                        </div>
                    </div>
                </template>
            </div>
        </details>
        
        <!-- Action Buttons -->
        <div class="flex gap-3 pt-4 border-t border-gray-200 dark:border-gray-600">
            <button @click.stop="markAsRemediated(prediction)"
                    class="flex-1 px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors font-medium">
                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Mark Remediated
            </button>
            <button @click.stop="showDetails(prediction)"
                    class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors font-medium">
                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                View Details
            </button>
        </div>
    </div>
    
    <!-- Hover Effect Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-blue-500/0 to-purple-500/0 hover:from-blue-500/5 hover:to-purple-500/5 rounded-lg pointer-events-none transition-all duration-300"></div>
</div>