<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: false }" x-bind:class="{ 'dark': darkMode }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{% if title %}{{ title }} - {% endif %}{{ site.title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:image" content="{{ site.url }}/assets/images/nope-og.png">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% if title %}{{ title }} - {% endif %}{{ site.title }}">
    <meta name="twitter:description" content="{{ description or site.description }}">
    <meta name="twitter:image" content="{{ site.url }}/assets/images/nope-og.png">
    
    <!-- Preload critical resources -->
    <link rel="preload" href="/assets/css/main.css" as="style">
    <link rel="preload" href="/assets/js/prediction-engine.js" as="script">
    
    <!-- Critical CSS (inlined for performance) -->
    <style>
      /* Critical above-the-fold styles */
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
      .loading { opacity: 0.5; pointer-events: none; }
      .nope-logo { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
      .hero-gradient { background: linear-gradient(135deg, #1e3a8a 0%, #3730a3 100%); }
    </style>
    
    <!-- Main CSS -->
    <link rel="stylesheet" href="/assets/css/main.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/images/nope-icon.svg">
    <link rel="apple-touch-icon" href="/assets/images/nope-180.png">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    
    <!-- Security headers -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' wss: https:;">
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="DENY">
    <meta http-equiv="X-XSS-Protection" content="1; mode=block">
    <meta name="referrer" content="strict-origin-when-cross-origin">
    
    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "{{ site.title }}",
      "description": "{{ site.description }}",
      "url": "{{ site.url }}",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    </script>
    
    <!-- Performance monitoring -->
    <script>
      // Track Core Web Vitals
      const webVitals = {
        start: performance.now(),
        navigation: performance.getEntriesByType('navigation')[0]
      };
      
      // Track LCP, FID, CLS
      if ('web-vitals' in window) {
        import('/assets/js/web-vitals.js').then(({ getLCP, getFID, getCLS }) => {
          getLCP(console.log);
          getFID(console.log);
          getCLS(console.log);
        });
      }
    </script>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300">
    <!-- Skip to main content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-blue-600 text-white px-4 py-2 rounded-md z-50">
        Skip to main content
    </a>
    
    <!-- Header -->
    <header class="sticky top-0 z-40 w-full border-b border-gray-200 dark:border-gray-700 bg-white/90 dark:bg-gray-900/90 backdrop-blur supports-[backdrop-filter]:bg-white/60 dark:supports-[backdrop-filter]:bg-gray-900/60">
        <div class="container mx-auto px-4 py-4">
            <nav class="flex items-center justify-between" role="navigation" aria-label="Main navigation">
                <!-- Logo and title -->
                <div class="flex items-center space-x-4">
                    <div class="nope-logo w-12 h-12 rounded-lg flex items-center justify-center text-white font-bold text-xl">
                        🐙
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold">
                            <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                                NOPE
                            </a>
                        </h1>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Predictive CVE Intelligence</p>
                    </div>
                </div>
                
                <!-- Navigation menu -->
                <div class="hidden md:flex items-center space-x-6">
                    <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">
                        Dashboard
                    </a>
                    <a href="/predictions.html" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">
                        Predictions
                    </a>
                    <a href="/early-warnings.html" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">
                        Early Warnings
                    </a>
                    <a href="/analytics.html" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">
                        Analytics
                    </a>
                </div>
                
                <!-- Dark mode toggle and mobile menu -->
                <div class="flex items-center space-x-4">
                    <!-- Dark mode toggle -->
                    <button @click="darkMode = !darkMode" 
                            class="p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                            aria-label="Toggle dark mode">
                        <span x-show="!darkMode">🌙</span>
                        <span x-show="darkMode">☀️</span>
                    </button>
                    
                    <!-- Mobile menu button -->
                    <button x-data="{ open: false }" @click="open = !open"
                            class="md:hidden p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                            aria-label="Toggle mobile menu">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </nav>
            
            <!-- Mobile menu -->
            <div x-data="{ open: false }" x-show="open" x-transition
                 class="md:hidden mt-4 py-4 border-t border-gray-200 dark:border-gray-700">
                <div class="space-y-2">
                    <a href="/" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-md transition-colors">
                        Dashboard
                    </a>
                    <a href="/predictions.html" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-md transition-colors">
                        Predictions
                    </a>
                    <a href="/early-warnings.html" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-md transition-colors">
                        Early Warnings
                    </a>
                    <a href="/analytics.html" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-md transition-colors">
                        Analytics
                    </a>
                </div>
            </div>
        </div>
    </header>
    
    <!-- Loading indicator -->
    <div id="global-loading" class="fixed inset-0 bg-black/20 backdrop-blur-sm z-50 flex items-center justify-center" style="display: none;">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 flex items-center space-x-4">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
            <span class="text-lg font-medium">Loading NOPE intelligence...</span>
        </div>
    </div>
    
    <!-- Main content -->
    <main id="main-content" class="min-h-screen" role="main">
        {{ content | safe }}
    </main>
    
    <!-- Footer -->
    <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 py-12">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <!-- About -->
                <div>
                    <h3 class="font-bold text-lg mb-4">About NOPE</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
                        Predictive CVE Intelligence Platform using EPSS filtering and machine learning 
                        to identify vulnerabilities with high exploitation probability.
                    </p>
                    <div class="flex space-x-4">
                        <a href="https://github.com/williamzujkowski/NOPE" target="_blank" rel="noopener noreferrer"
                           class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                            <span class="sr-only">GitHub</span>
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 0C5.374 0 0 5.373 0 12 0 17.302 3.438 21.8 8.207 23.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                            </svg>
                        </a>
                    </div>
                </div>
                
                <!-- Data Sources -->
                <div>
                    <h3 class="font-bold text-lg mb-4">Data Sources</h3>
                    <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                        <li><a href="https://www.first.org/epss/" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">EPSS (FIRST.org)</a></li>
                        <li><a href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">CISA KEV</a></li>
                        <li><a href="https://cve.mitre.org/" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">CVE Database</a></li>
                        <li><a href="https://github.com/advisories" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">GitHub Advisory DB</a></li>
                        <li><a href="https://deps.dev/" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">deps.dev</a></li>
                    </ul>
                </div>
                
                <!-- Quick Links -->
                <div>
                    <h3 class="font-bold text-lg mb-4">Quick Links</h3>
                    <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                        <li><a href="/api/predictions/latest.json" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">API: Latest Predictions</a></li>
                        <li><a href="/api/early-warnings.json" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">API: Early Warnings</a></li>
                        <li><a href="/api/metrics/accuracy.json" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">API: Accuracy Metrics</a></li>
                        <li><a href="/sitemap.xml" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Sitemap</a></li>
                    </ul>
                </div>
                
                <!-- Stats -->
                <div>
                    <h3 class="font-bold text-lg mb-4">Platform Stats</h3>
                    <div class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                        <div>Built: {{ site.buildDate | readableDate }}</div>
                        <div>Version: {{ site.version }}</div>
                        <div>Last Updated: <span id="last-updated"></span></div>
                        <div class="text-xs mt-4 text-gray-500 dark:text-gray-500">
                            <div>WCAG 2.1 AA Compliant</div>
                            <div>&lt;3s Load Time on 3G</div>
                            <div>Real-time WebSocket Updates</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Copyright -->
            <div class="border-t border-gray-200 dark:border-gray-700 mt-8 pt-8 text-center text-sm text-gray-600 dark:text-gray-400">
                <p>&copy; 2024 NOPE (Network Operational Patch Evaluator). Built with predictive intelligence.</p>
                <p class="mt-2">🐙 "NOPE to vulnerabilities, YES to proactive security!" 🐙</p>
            </div>
        </div>
    </footer>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js"></script>
    <script src="/assets/js/prediction-engine.js"></script>
    
    <!-- Service Worker for offline functionality -->
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js', { scope: '/' })
          .then(registration => console.log('SW registered'))
          .catch(error => console.log('SW registration failed'));
      }
    </script>
    
    <!-- Update last updated time -->
    <script>
      document.getElementById('last-updated').textContent = new Date().toLocaleString();
    </script>
</body>
</html>