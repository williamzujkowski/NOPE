---
layout: layouts/base.njk
title: Early Warning System
description: Real-time early warning system detecting vulnerability exploitation signals 14-21 days in advance
---

<div x-data="nopeDashboard()" x-init="init(); view = 'early-warnings'" class="container mx-auto px-4 py-8">
    <!-- Early Warning Header -->
    <div class="bg-gradient-to-r from-yellow-400 via-orange-500 to-red-600 rounded-2xl p-8 mb-8 text-white relative overflow-hidden">
        <!-- Animated Background -->
        <div class="absolute inset-0 opacity-20">
            <div class="absolute inset-0 bg-repeat animate-pulse" style="background-image: url('data:image/svg+xml,<svg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"><g fill=\"none\" fill-rule=\"evenodd\"><g fill=\"%23fff\" fill-opacity=\"0.1\"><circle cx=\"7\" cy=\"7\" r=\"2\"/><circle cx=\"7\" cy=\"27\" r=\"2\"/><circle cx=\"7\" cy=\"47\" r=\"2\"/><circle cx=\"27\" cy=\"7\" r=\"2\"/><circle cx=\"27\" cy=\"27\" r=\"2\"/><circle cx=\"27\" cy=\"47\" r=\"2\"/><circle cx=\"47\" cy=\"7\" r=\"2\"/><circle cx=\"47\" cy=\"27\" r=\"2\"/><circle cx=\"47\" cy=\"47\" r=\"2\"/></g></g></svg>');"></div>
        </div>
        
        <div class="relative flex flex-col lg:flex-row items-center justify-between">
            <div class="text-center lg:text-left mb-6 lg:mb-0">
                <div class="flex items-center justify-center lg:justify-start gap-4 mb-4">
                    <div class="relative">
                        <span class="text-5xl animate-bounce">⚡</span>
                        <div class="absolute inset-0 rounded-full border-2 border-white animate-ping"></div>
                    </div>
                    <div>
                        <h1 class="text-4xl lg:text-5xl font-bold">Early Warning System</h1>
                        <div class="flex items-center gap-2 mt-2">
                            <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
                            <span class="text-lg">Real-time monitoring active</span>
                        </div>
                    </div>
                </div>
                <p class="text-xl opacity-90 mb-2">
                    Advanced threat detection 14-21 days before exploitation
                </p>
                <p class="opacity-80">
                    Powered by ML correlation engines and global intelligence feeds
                </p>
            </div>
            
            <!-- Live Stats -->
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center">
                    <div class="text-3xl font-bold" x-text="earlyWarnings.length"></div>
                    <div class="text-sm opacity-80">Active Warnings</div>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center">
                    <div class="text-3xl font-bold" x-text="earlyWarnings.filter(w => w.warning_score >= 0.8).length"></div>
                    <div class="text-sm opacity-80">Critical Alerts</div>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center">
                    <div class="text-3xl font-bold">18</div>
                    <div class="text-sm opacity-80">Avg Warning Days</div>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center">
                    <div class="text-3xl font-bold">92%</div>
                    <div class="text-sm opacity-80">Accuracy Rate</div>
                </div>
            </div>
        </div>
        
        <!-- Status Bar -->
        <div class="absolute bottom-0 left-0 right-0 h-2 bg-white/20">
            <div class="h-full bg-gradient-to-r from-green-400 to-blue-400 animate-pulse" 
                 :style="`width: ${Math.min(100, earlyWarnings.length * 10)}%`"></div>
        </div>
    </div>
    
    <!-- Loading State -->
    <div x-show="loading" class="text-center py-20">
        <div class="animate-spin rounded-full h-16 w-16 border-b-2 border-yellow-600 mx-auto mb-4"></div>
        <h2 class="text-xl font-semibold mb-2">Loading Early Warning Intelligence...</h2>
        <p class="text-gray-600 dark:text-gray-400">Analyzing threat signals and correlation patterns</p>
    </div>
    
    <!-- Main Content -->
    <div x-show="!loading" style="display: none;" x-transition>
        <!-- Intelligence Sources Panel -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6 mb-8">
            <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                Intelligence Sources & Signal Strength
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Honeypot Networks -->
                <div class="p-4 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                            <span class="font-medium">Honeypot Networks</span>
                        </div>
                        <span class="text-sm text-green-600 dark:text-green-400 font-bold">98%</span>
                    </div>
                    <p class="text-xs text-green-700 dark:text-green-300">Global scanning activity detected</p>
                </div>
                
                <!-- DNS Anomalies -->
                <div class="p-4 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 bg-blue-500 rounded-full animate-pulse"></div>
                            <span class="font-medium">DNS Anomalies</span>
                        </div>
                        <span class="text-sm text-blue-600 dark:text-blue-400 font-bold">85%</span>
                    </div>
                    <p class="text-xs text-blue-700 dark:text-blue-300">Suspicious domain registrations</p>
                </div>
                
                <!-- Dark Web Monitoring -->
                <div class="p-4 rounded-lg bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 bg-purple-500 rounded-full animate-pulse"></div>
                            <span class="font-medium">Dark Web Chatter</span>
                        </div>
                        <span class="text-sm text-purple-600 dark:text-purple-400 font-bold">72%</span>
                    </div>
                    <p class="text-xs text-purple-700 dark:text-purple-300">Underground forum discussions</p>
                </div>
                
                <!-- Exploit Development -->
                <div class="p-4 rounded-lg bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 bg-orange-500 rounded-full animate-pulse"></div>
                            <span class="font-medium">Exploit Development</span>
                        </div>
                        <span class="text-sm text-orange-600 dark:text-orange-400 font-bold">91%</span>
                    </div>
                    <p class="text-xs text-orange-700 dark:text-orange-300">GitHub PoC repositories</p>
                </div>
            </div>
        </div>
        
        <!-- Early Warning Alerts -->
        <div class="space-y-6">
            <!-- No Warnings State -->
            <div x-show="earlyWarnings.length === 0" class="text-center py-20">
                <div class="text-6xl mb-4">🛡️</div>
                <h3 class="text-xl font-semibold mb-2 text-green-600">All Clear!</h3>
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    No early warning signals detected at this time
                </p>
                <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 max-w-md mx-auto">
                    <p class="text-sm text-green-700 dark:text-green-300">
                        🔍 System is actively monitoring threat intelligence feeds<br>
                        📡 Real-time correlation engines are running<br>
                        🎯 Will alert 14-21 days before exploitation
                    </p>
                </div>
            </div>
            
            <!-- Warning Cards -->
            <div x-show="earlyWarnings.length > 0">
                <template x-for="(warning, index) in earlyWarnings" :key="warning.cve_id">
                    <div class="bg-gradient-to-r from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 rounded-xl border-2 border-yellow-300 dark:border-yellow-600 p-6 shadow-lg animate-fade-in">
                        <!-- Warning Header -->
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex items-center gap-4">
                                <!-- Severity Indicator -->
                                <div class="relative">
                                    <div :class="{
                                        'text-red-500': warning.warning_score >= 0.8,
                                        'text-orange-500': warning.warning_score >= 0.6 && warning.warning_score < 0.8,
                                        'text-yellow-500': warning.warning_score < 0.6
                                    }" class="text-4xl">
                                        <span x-show="warning.warning_score >= 0.8">🔴</span>
                                        <span x-show="warning.warning_score >= 0.6 && warning.warning_score < 0.8">🟠</span>
                                        <span x-show="warning.warning_score < 0.6">🟡</span>
                                    </div>
                                    <div class="absolute inset-0 rounded-full border-2 border-current animate-ping opacity-30"></div>
                                </div>
                                
                                <div>
                                    <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100" x-text="warning.cve_id"></h3>
                                    <p class="text-orange-700 dark:text-orange-300 font-medium" x-text="warning.reason || 'Early exploitation signals detected'"></p>
                                </div>
                            </div>
                            
                            <!-- Warning Score -->
                            <div class="text-right">
                                <div class="text-3xl font-bold text-orange-600 dark:text-orange-400" 
                                     x-text="`${(warning.warning_score * 100).toFixed(0)}%`"></div>
                                <div class="text-sm text-orange-600 dark:text-orange-400">Alert Score</div>
                            </div>
                        </div>
                        
                        <!-- Warning Details -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                            <!-- Signal Details -->
                            <div>
                                <h4 class="font-semibold mb-3 text-gray-900 dark:text-gray-100">Detection Signals</h4>
                                <div class="space-y-2">
                                    <div class="flex items-center justify-between p-2 bg-white/50 dark:bg-gray-800/50 rounded">
                                        <span class="text-sm">Scanning Activity</span>
                                        <div class="flex items-center gap-2">
                                            <div class="w-16 bg-gray-200 dark:bg-gray-600 rounded-full h-2">
                                                <div class="bg-red-500 h-2 rounded-full" style="width: 85%"></div>
                                            </div>
                                            <span class="text-sm font-medium">85%</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between p-2 bg-white/50 dark:bg-gray-800/50 rounded">
                                        <span class="text-sm">PoC Development</span>
                                        <div class="flex items-center gap-2">
                                            <div class="w-16 bg-gray-200 dark:bg-gray-600 rounded-full h-2">
                                                <div class="bg-orange-500 h-2 rounded-full" style="width: 72%"></div>
                                            </div>
                                            <span class="text-sm font-medium">72%</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between p-2 bg-white/50 dark:bg-gray-800/50 rounded">
                                        <span class="text-sm">Underground Chatter</span>
                                        <div class="flex items-center gap-2">
                                            <div class="w-16 bg-gray-200 dark:bg-gray-600 rounded-full h-2">
                                                <div class="bg-yellow-500 h-2 rounded-full" style="width: 45%"></div>
                                            </div>
                                            <span class="text-sm font-medium">45%</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Timeline & Prediction -->
                            <div>
                                <h4 class="font-semibold mb-3 text-gray-900 dark:text-gray-100">Exploitation Timeline</h4>
                                <div class="space-y-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                                        <div class="text-sm">
                                            <span class="font-medium">Signal Detection:</span>
                                            <span class="text-gray-600 dark:text-gray-400">Today</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                                        <div class="text-sm">
                                            <span class="font-medium">Expected PoC Release:</span>
                                            <span class="text-gray-600 dark:text-gray-400">7-10 days</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <div class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></div>
                                        <div class="text-sm">
                                            <span class="font-medium">Predicted Exploitation:</span>
                                            <span class="font-bold text-red-600 dark:text-red-400" x-text="`${warning.predicted_days || 14}-${(warning.predicted_days || 14) + 7} days`"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Recommendations -->
                        <div class="bg-blue-50 dark:bg-blue-900/30 rounded-lg p-4 mb-4">
                            <h4 class="font-semibold mb-2 text-blue-900 dark:text-blue-100 flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                Recommended Actions
                            </h4>
                            <ul class="text-sm text-blue-800 dark:text-blue-200 space-y-1">
                                <li class="flex items-center gap-2">
                                    <span class="text-green-600">✓</span>
                                    Immediate patch assessment and testing
                                </li>
                                <li class="flex items-center gap-2">
                                    <span class="text-green-600">✓</span>
                                    Enhanced monitoring for affected systems
                                </li>
                                <li class="flex items-center gap-2">
                                    <span class="text-green-600">✓</span>
                                    Prepare emergency response procedures
                                </li>
                                <li class="flex items-center gap-2">
                                    <span class="text-orange-600">⚠</span>
                                    Consider temporary mitigations
                                </li>
                            </ul>
                        </div>
                        
                        <!-- Action Buttons -->
                        <div class="flex flex-wrap gap-3">
                            <button @click="showPredictionDetails(warning)" 
                                    class="px-4 py-2 bg-orange-600 text-white rounded-md hover:bg-orange-700 transition-colors font-medium">
                                View Full Analysis
                            </button>
                            <button class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors font-medium">
                                Export Report
                            </button>
                            <button class="px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors font-medium">
                                Mark as Reviewed
                            </button>
                        </div>
                    </div>
                </template>
            </div>
        </div>
        
        <!-- System Health Panel -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6 mt-8">
            <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Early Warning System Health
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- System Status -->
                <div>
                    <h3 class="font-medium mb-3">System Status</h3>
                    <div class="space-y-2">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                            <span class="text-sm">Correlation Engine: Active</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                            <span class="text-sm">Intelligence Feeds: 47/47 Online</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                            <span class="text-sm">ML Models: All Operational</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-yellow-500 rounded-full"></div>
                            <span class="text-sm">Pattern Recognition: Learning</span>
                        </div>
                    </div>
                </div>
                
                <!-- Recent Activity -->
                <div>
                    <h3 class="font-medium mb-3">Recent Activity (24h)</h3>
                    <div class="space-y-2 text-sm">
                        <div>🔍 <strong>1,247</strong> signals analyzed</div>
                        <div>🎯 <strong>23</strong> patterns detected</div>
                        <div>⚡ <strong>5</strong> early warnings generated</div>
                        <div>📊 <strong>2</strong> confirmed predictions</div>
                    </div>
                </div>
                
                <!-- Next Update -->
                <div>
                    <h3 class="font-medium mb-3">Next Update</h3>
                    <div class="text-sm text-gray-600 dark:text-gray-400">
                        <div class="mb-2">Intelligence feeds refresh every 15 minutes</div>
                        <div class="mb-2">ML models retrain daily at 02:00 UTC</div>
                        <div>Full system health check: <strong>Next in 3h 24m</strong></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>