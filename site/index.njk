---
layout: layouts/base.njk
title: Dashboard
description: NOPE Dashboard - Predictive CVE Intelligence with real-time threat monitoring and early warning system
---

<div x-data="nopeDashboard()" x-init="init()" class="container mx-auto px-4 py-8">
    <!-- Loading State -->
    <div x-show="loading" class="text-center py-20">
        <div class="animate-spin rounded-full h-16 w-16 border-b-2 border-blue-600 mx-auto mb-4"></div>
        <h2 class="text-xl font-semibold mb-2">Loading NOPE Intelligence...</h2>
        <p class="text-gray-600 dark:text-gray-400">Analyzing predictive signals and threat correlations</p>
    </div>
    
    <!-- Dashboard Content -->
    <div x-show="!loading" style="display: none;" x-transition>
        <!-- Hero Section -->
        <div class="hero-gradient rounded-2xl p-8 mb-8 text-white">
            <div class="flex flex-col md:flex-row items-center justify-between">
                <div class="text-center md:text-left mb-6 md:mb-0">
                    <h1 class="text-4xl md:text-5xl font-bold mb-4">
                        🐙 NOPE Dashboard
                    </h1>
                    <p class="text-xl opacity-90 mb-4">
                        Predictive CVE Intelligence Platform
                    </p>
                    <p class="opacity-80">
                        Advanced machine learning models predict vulnerability exploitation 14-21 days in advance
                    </p>
                </div>
                
                <!-- Quick Stats -->
                <div class="grid grid-cols-2 gap-4 text-center">
                    <div class="bg-white/10 rounded-lg p-4">
                        <div class="text-3xl font-bold" x-text="stats.total_monitored"></div>
                        <div class="text-sm opacity-80">CVEs Monitored</div>
                    </div>
                    <div class="bg-white/10 rounded-lg p-4">
                        <div class="text-3xl font-bold" x-text="stats.high_risk"></div>
                        <div class="text-sm opacity-80">High Risk</div>
                    </div>
                    <div class="bg-white/10 rounded-lg p-4">
                        <div class="text-3xl font-bold" x-text="`${stats.accuracy_rate}%`"></div>
                        <div class="text-sm opacity-80">Accuracy</div>
                    </div>
                    <div class="bg-white/10 rounded-lg p-4">
                        <div class="text-3xl font-bold" x-text="stats.average_warning_days"></div>
                        <div class="text-sm opacity-80">Avg Warning Days</div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Alert Panel for Early Warnings -->
        {% include 'components/early-warning-alert.njk' %}
        
        <!-- Filter Controls -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-8">
            <h2 class="text-lg font-semibold mb-4">Filter & Search</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Threat Level Filter -->
                <div>
                    <label class="block text-sm font-medium mb-2">Threat Level</label>
                    <select x-model="filters.threat_level" @change="calculateStats()"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700">
                        <option value="all">All Levels</option>
                        <option value="CRITICAL">Critical</option>
                        <option value="HIGH">High</option>
                        <option value="ELEVATED">Elevated</option>
                        <option value="MODERATE">Moderate</option>
                        <option value="LOW">Low</option>
                    </select>
                </div>
                
                <!-- Confidence Filter -->
                <div>
                    <label class="block text-sm font-medium mb-2">Min Confidence</label>
                    <input type="range" x-model="filters.confidence_min" @input="calculateStats()"
                           min="0" max="1" step="0.1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700">
                    <div class="text-sm text-gray-600 dark:text-gray-400 mt-1" 
                         x-text="`${(filters.confidence_min * 100).toFixed(0)}%`"></div>
                </div>
                
                <!-- Time Range Filter -->
                <div>
                    <label class="block text-sm font-medium mb-2">Time Range</label>
                    <select x-model="filters.time_range" @change="calculateStats()"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700">
                        <option value="24h">Last 24 Hours</option>
                        <option value="7d">Last 7 Days</option>
                        <option value="30d">Last 30 Days</option>
                        <option value="all">All Time</option>
                    </select>
                </div>
                
                <!-- Toggle Options -->
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="checkbox" x-model="filters.show_early_warnings" @change="calculateStats()"
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <span class="ml-2 text-sm">Early Warnings</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" x-model="filters.show_exploited_only" @change="calculateStats()"
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <span class="ml-2 text-sm">Exploitation Predicted</span>
                    </label>
                </div>
            </div>
        </div>
        
        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- Risk Distribution Chart -->
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold mb-4">Risk Distribution</h3>
                <div class="relative h-64">
                    <canvas id="riskDistributionChart"></canvas>
                </div>
            </div>
            
            <!-- Accuracy Timeline -->
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold mb-4">Prediction Accuracy Timeline</h3>
                <div id="accuracyTimeline" class="h-64"></div>
            </div>
        </div>
        
        <!-- Predictions Grid -->
        <div class="mb-8">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold">Current Predictions</h2>
                <div class="flex items-center space-x-4">
                    <span class="text-sm text-gray-600 dark:text-gray-400" 
                          x-text="`${getFilteredPredictions().length} predictions`"></span>
                    <button @click="refreshPredictions()"
                            class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors">
                        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        Refresh
                    </button>
                </div>
            </div>
            
            <!-- Predictions Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
                <template x-for="prediction in getFilteredPredictions().slice(0, 12)" :key="prediction.cve_id">
                    <div>
                        {% include 'components/nope-card.njk' %}
                    </div>
                </template>
            </div>
            
            <!-- Show More Button -->
            <div x-show="getFilteredPredictions().length > 12" class="text-center mt-8">
                <a href="/predictions.html" 
                   class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition-colors">
                    View All Predictions
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>
        
        <!-- Progress Overview -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-8">
            <h3 class="text-lg font-semibold mb-4">Progress Overview</h3>
            <div class="text-sm font-mono text-gray-600 dark:text-gray-400">
                <div>📊 Total Tasks: <span x-text="stats.total_monitored"></span></div>
                <div>✅ Completed: <span x-text="stats.exploited_correctly_predicted"></span> (<span x-text="`${(stats.exploited_correctly_predicted/stats.total_monitored*100).toFixed(1)}%`"></span>)</div>
                <div>🔄 In Progress: <span x-text="stats.high_risk"></span> (<span x-text="`${(stats.high_risk/stats.total_monitored*100).toFixed(1)}%`"></span>)</div>
                <div>⭕ Pending: <span x-text="stats.total_monitored - stats.high_risk - stats.exploited_correctly_predicted"></span></div>
                <div class="mt-2">
                    <div>Priority indicators: 🔴 HIGH/CRITICAL, 🟡 MEDIUM, 🟢 LOW</div>
                    <div>Confidence: ✅ High (&gt;80%), 🟡 Medium (60-80%), ❌ Low (&lt;60%)</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Prediction Details Modal -->
<div x-show="selectedPrediction" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-50 overflow-y-auto" style="display: none;">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75" @click="selectedPrediction = null"></div>
        
        <div class="inline-block w-full max-w-4xl my-8 overflow-hidden text-left align-middle transition-all transform bg-white dark:bg-gray-800 shadow-xl rounded-lg">
            <!-- Modal content will be populated by JavaScript -->
            <div x-show="selectedPrediction" class="p-6">
                <div class="flex items-start justify-between mb-6">
                    <div>
                        <h2 class="text-2xl font-bold" x-text="selectedPrediction?.cve_id"></h2>
                        <p class="text-gray-600 dark:text-gray-400 mt-1" x-text="selectedPrediction?.description"></p>
                    </div>
                    <button @click="selectedPrediction = null" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                
                <!-- Detailed prediction information will be rendered here -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Risk Assessment -->
                    <div class="space-y-4">
                        <h3 class="font-semibold text-lg">Risk Assessment</h3>
                        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
                            <div class="text-3xl font-bold mb-2" x-text="selectedPrediction?.risk_score"></div>
                            <div class="text-sm text-gray-600 dark:text-gray-400">NOPE Risk Score</div>
                        </div>
                    </div>
                    
                    <!-- Model Contributions -->
                    <div class="space-y-4">
                        <h3 class="font-semibold text-lg">Model Contributions</h3>
                        <div class="space-y-2" x-show="selectedPrediction?.model_contributions">
                            <template x-for="[model, contribution] in Object.entries(selectedPrediction?.model_contributions || {})" :key="model">
                                <div class="flex justify-between items-center">
                                    <span class="text-sm" x-text="model.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())"></span>
                                    <div class="flex items-center space-x-2">
                                        <div class="w-16 bg-gray-200 dark:bg-gray-600 rounded-full h-2">
                                            <div class="bg-blue-600 h-2 rounded-full" :style="`width: ${contribution * 100}%`"></div>
                                        </div>
                                        <span class="text-sm font-medium" x-text="`${(contribution * 100).toFixed(1)}%`"></span>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>